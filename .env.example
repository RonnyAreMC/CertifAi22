DEBUG=False
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
ALLOWED_HOSTS=tu-dominio.up.railway.app,localhost,127.0.0.1

# Base de datos (Railway la inyecta automáticamente al añadir Postgres)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-correo@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password

# HTTPS (déjalo en True en producción)
SECURE_SSL_REDIRECT=True

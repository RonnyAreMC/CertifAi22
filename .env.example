# Configuración local · copia este archivo como `.env` y completa los valores
# NUNCA hacer commit de `.env` con secrets reales.

# ── Django ───────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=dev-local-key-not-for-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
SECURE_SSL_REDIRECT=False

# ── Base de datos ────────────────────────────────────────────────
# En dev se usa SQLite. Para Postgres (Docker o producción):
# DATABASE_URL=postgres://certifai:certifai@localhost:5432/certifai

# ── Celery / Redis ───────────────────────────────────────────────
# Si no se setea y DEBUG=True, Celery corre EAGER (sincrónico, sin Redis)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=False

# ── Email ────────────────────────────────────────────────────────
# Backend Gmail API (usa el OAuth de la cuenta institucional)
EMAIL_BACKEND=core.services.email.backend.GmailAPIBackend
DEFAULT_FROM_EMAIL=CertifAI <noreply@example.com>

# Fallback SMTP si querés usar Django console / SMTP en vez de Gmail API:
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu-correo@gmail.com
# EMAIL_HOST_PASSWORD=tu-app-password

# ── Google OAuth (Meet · Calendar · Drive · Gmail · Sign-In) ─────
# Crea un cliente OAuth Web en https://console.cloud.google.com/apis/credentials
# y añade las URIs de redirección autorizadas:
#   http://localhost:8500/panel/google/callback/
#   http://localhost:8500/cuenta/google/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8500/panel/google/callback/
GOOGLE_OAUTH_EMAIL=tu-cuenta-institucional@ejemplo.edu.ec
GOOGLE_PROJECT_ID=

# ── Sentry (opcional, observabilidad) ────────────────────────────
# SENTRY_DSN=
